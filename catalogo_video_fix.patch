+/**
+ * Converte links comuns (YouTube, Google Drive, Vimeo) na URL de incorporação
+ * que funciona dentro de um <iframe>. Links de "watch"/"view"/compartilhamento
+ * são bloqueados pelo navegador (X-Frame-Options) e ficam com a tela em branco.
+ */
+function toEmbedUrl(url) {
+  if (!url) return '';
+  const u = String(url).trim();
+
+  // YouTube: youtu.be/ID, watch?v=ID, /shorts/ID, /embed/ID
+  const yt = u.match(/(?:youtube\.com\/(?:watch\?(?:.*&)?v=|embed\/|shorts\/)|youtu\.be\/)([A-Za-z0-9_-]{11})/);
+  if (yt) return `https://www.youtube.com/embed/${yt[1]}`;
+
+  // Vimeo: vimeo.com/12345678
+  const vm = u.match(/vimeo\.com\/(?:video\/)?(\d+)/);
+  if (vm) return `https://player.vimeo.com/video/${vm[1]}`;
+
+  // Google Drive: extrai o fileId de /d/ID, ?id=ID, /file/d/ID e usa /preview
+  const drive = u.match(/(?:drive|docs)\.google\.com\/(?:file\/d\/|.*[?&]id=)([A-Za-z0-9_-]{20,})/);
+  if (drive) return `https://drive.google.com/file/d/${drive[1]}/preview`;
+
+  // Já é um /preview ou /embed do Google ou outro embed direto → mantém
+  return u;
+}
